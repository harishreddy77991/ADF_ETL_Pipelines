{
	"name": "transCSV",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_DF_SOU",
						"type": "DatasetReference"
					},
					"name": "sourceCSV"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_DF_DES",
						"type": "DatasetReference"
					},
					"name": "sink"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "filterrows"
				},
				{
					"name": "split1"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Index as short,",
				"          Name as string,",
				"          Description as string,",
				"          Brand as string,",
				"          Category as string,",
				"          Price as short,",
				"          Currency as string,",
				"          Stock as short,",
				"          EAN as long,",
				"          Color as string,",
				"          Size as string,",
				"          Availability as string,",
				"          {Internal ID} as short",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceCSV",
				"sourceCSV select(mapColumn(",
				"          Index,",
				"          Name,",
				"          Description,",
				"          Category,",
				"          Price,",
				"          Currency,",
				"          Stock,",
				"          Availability,",
				"          {Internal ID}",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 filter(Price < 500) ~> filterrows",
				"filterrows split(Category=='Skincare',",
				"     Category=='Laptops & Computers',",
				"     disjoint: false) ~> split1@(skincare, LaptopsComputers, othercategorys)",
				"split1@skincare derive(Currency = iif(Currency == 'USD', 'INR', Currency)) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink"
			]
		}
	}
}